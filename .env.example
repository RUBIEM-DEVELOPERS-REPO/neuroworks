# Copy to .env and fill in. .env is gitignored.
# Sections below cluster related settings so it's easy to spot what's
# missing or what you might want to flip. The commented-out lines are
# all optional — uncommented defaults are the minimum to boot.


# ═════════════════════════════════════════════════════════════════════
# Required — GitHub + vault
# ═════════════════════════════════════════════════════════════════════

# GitHub PAT — same scope as NEUROWORKS_PAT in the cron workflow
# (Contents r/w on vault repo, r across owned repos, Metadata/PRs/Issues r).
GITHUB_TOKEN=ghp_paste_here

# Owner used by publish-folder and the NeuroWorks UI.
GITHUB_OWNER=RUBIEM-DEVELOPERS-REPO

# Vault repo (owner/name). clawbot writes summaries + reflections here.
VAULT_REPO=RUBIEM-DEVELOPERS-REPO/main-brain

# Local path to the Obsidian vault. Server reads/writes here.
VAULT_PATH=D:\Main brain


# ═════════════════════════════════════════════════════════════════════
# Local LLM (Ollama)
# ═════════════════════════════════════════════════════════════════════

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
# Per-profile pins. Leave blank to use OLLAMA_MODEL for all profiles.
# OLLAMA_TRIAGE_MODEL=qwen3.5:0.8b
# OLLAMA_PLAN_MODEL=qwen2.5:3b
# OLLAMA_SYNTH_MODEL=qwen2.5:3b
# OLLAMA_EXTRACT_MODEL=qwen2.5:3b
# OLLAMA_BALANCED_MODEL=qwen2.5:3b


# ═════════════════════════════════════════════════════════════════════
# Optional cloud backends — uncomment to enable
# ═════════════════════════════════════════════════════════════════════

# --- OpenRouter (big speed gain on planning + synthesis) -------------
# Leaving OPENROUTER_API_KEY blank keeps everything 100% local on Ollama.
# Per-profile pins win over OPENROUTER_MODEL; OPENROUTER_PROFILES narrows
# which profiles use OR (empty + key set = OR is default for everything).
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_LARGE_MODEL=openai/gpt-4o
# OPENROUTER_PROFILES=planning,synthesis,triage,extraction,balanced
# OPENROUTER_PLAN_MODEL=openai/gpt-4o-mini
# OPENROUTER_SYNTH_MODEL=anthropic/claude-3.5-haiku
# OPENROUTER_TRIAGE_MODEL=openai/gpt-4o-mini
# OPENROUTER_EXTRACT_MODEL=openai/gpt-4o-mini
# OPENROUTER_BALANCED_MODEL=openai/gpt-4o-mini
# OPENROUTER_APP_URL=https://neuroworks.local
# OPENROUTER_APP_NAME=NeuroWorks Clawbot
# Resilience: on a transient OpenRouter failure (429 rate-limit / 5xx / network)
# we retry up to NEUROWORKS_OR_MAX_ATTEMPTS with backoff, then fall back to the
# local Ollama model so a temporary upstream rate-limit doesn't fail the task.
# Set NEUROWORKS_OR_FALLBACK_OLLAMA=0 to disable the fallback (hard-fail instead).
# NEUROWORKS_OR_MAX_ATTEMPTS=3
# NEUROWORKS_OR_FALLBACK_OLLAMA=1

# --- Firecrawl (third-tier scraping when fetch + Playwright both fail) -
# Get a key from https://firecrawl.dev. With the key set, smartFetch
# tries Firecrawl after Playwright fails AND the web.firecrawl primitive
# becomes available to the planner.
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# --- MiniMax (optional cloud multimodal: LLM + speech + video + music) ---
# Get a key from https://platform.minimax.io. With MINIMAX_API_KEY set:
#   • the chat models (MiniMax-M3 / M2.7) become selectable as an explicit
#     LLM backend (pin a model name starting "MiniMax-…"), and
#   • the media.tts / media.video / media.music agent primitives turn on,
#     so Neuro can narrate answers, generate clips, and compose music.
# Docs index: https://platform.minimax.io/docs/llms.txt
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_ANTHROPIC_URL=https://api.minimax.io/anthropic
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_TTS_MODEL=speech-2.8-hd
# MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
# MINIMAX_MUSIC_MODEL=music-2.6
# MINIMAX_GROUP_ID=        # required only by the media (TTS/video/music) endpoints

# --- HeyGen (optional: AI avatar / spokesperson video) --------------
# Talking-head presenter videos from a script. With HEYGEN_API_KEY set, the
# media.avatar_video primitive turns on (+ media.avatars / media.voices to pick
# an avatar & voice). Async render (create → poll), takes a few minutes.
# HEYGEN_API_KEY=
# HEYGEN_BASE_URL=https://api.heygen.com


# ═════════════════════════════════════════════════════════════════════
# Payments — Stripe gateway (optional)
# ═════════════════════════════════════════════════════════════════════
# With STRIPE_SECRET_KEY set, the Payments page + payment.link / payment.status
# / payment.list primitives turn on: agents can create payment links to bill
# clients, and you can sell subscription plans. Use a test key (sk_test_…)
# while developing. Webhook secret enables recording paid events on Activity.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or the Dashboard webhook
# PAYMENTS_CURRENCY=zar             # default settlement currency
# PAYMENTS_SUCCESS_URL=https://neuroworks.local/paid
# PAYMENTS_CANCEL_URL=https://neuroworks.local/cancelled


# ═════════════════════════════════════════════════════════════════════
# Security gates — DEFAULT-ON, lift only when you understand the trade
# ═════════════════════════════════════════════════════════════════════

# Sensitive-path gate. When OFF, fs.read_external + fs.list_external
# refuse known-sensitive paths (.env, ~/.ssh, AWS/k8s creds, browser
# cookie stores, Windows registry hives, etc.). Set to 1 to lift.
# NEUROWORKS_FS_UNRESTRICTED=1

# SSRF / private-address gate. When OFF, web.fetch / web.scrape /
# web.firecrawl / skill.fetch_remote refuse private / loopback /
# link-local addresses (including 169.254.169.254 — cloud metadata).
# Set to 1 to allow agent tools to reach internal hosts.
# NEUROWORKS_WEB_ALLOW_PRIVATE=1

# Vault-write gate. When OFF, vault.edit refuses to mutate vault .md
# files. Reads (vault.read, vault.scan_docs, vault.search) are always on.
# NEUROWORKS_VAULT_EDIT=1

# Vault secret-scan. When 1 (default), writeVaultFile rejects any
# content whose security scan finds a high-severity match (API keys,
# private keys, etc.). Set to 0 to disable — strongly discouraged.
# NEUROWORKS_VAULT_SCAN=0

# Remote-skill fetch. When 1, skill.fetch_remote can pull skill .md
# files from public URLs into skills/_user/. Off by default since
# arbitrary remote skill content is a prompt-injection vector.
# NEUROWORKS_REMOTE_SKILLS=1

# Origin / DNS-rebinding guard. When 1 (default), /api enforces a Host
# + Origin allow-list. Set to 0 only if you run behind a reverse proxy
# that rewrites Host — disabling exposes the API to cross-origin POSTs
# and DNS-rebinding attacks. See README "Security" section.
# NEUROWORKS_ORIGIN_GUARD=0
# NEUROWORKS_WEB_ORIGIN=http://127.0.0.1:7470

# Enterprise mode. Off by default (trusts any same-machine or Origin-less
# caller — fine for a single loopback-bound instance). Set to 1 the moment
# this instance is reachable from a wider network: requires every non-exempt,
# non-same-machine request to carry a human session token or a
# "machine:full"-scoped API key. See docs/DEPLOYMENT-SECRETS.md.
# NEUROWORKS_ENTERPRISE_MODE=1


# ═════════════════════════════════════════════════════════════════════
# Performance + observability
# ═════════════════════════════════════════════════════════════════════

# Server bind port. Web auto-points to NEUROWORKS_PORT + 0 (so default
# 7471 backs the web UI at 7470).
NEUROWORKS_PORT=7471

# Sub-agent budgets. The agent runs steps in parallel within two
# lanes — LLM-bound (ollama.generate, research.deep, etc.) and I/O-
# bound (vault, github, fs, web.fetch). Each lane has a default cap
# that scales up when idle peers are available. Tune if you have a
# powerful machine or a slow one.
# NEUROWORKS_SUBAGENT_BUDGET=3
# NEUROWORKS_IO_BUDGET=6

# Per-worker overrides (managed secondary worker uses these by default).
# NEUROWORKS_WORKER_SUBAGENT_BUDGET=4
# NEUROWORKS_WORKER_IO_BUDGET=8

# Skip startup model warmup (faster boot, slower first request).
# NEUROWORKS_NO_WARMUP=1

# Skip startup peer auto-discovery scan (rare — only if your machine
# has many local services on 7471-7475 that respond on /api/peers/self).
# NEUROWORKS_NO_AUTODISCOVER=1

# Vault commit queue debounce (ms). Higher = fewer commits but slower
# "I saved a note" feedback. 0 = commit immediately (chatty).
# NEUROWORKS_COMMIT_DEBOUNCE_MS=4000

# Vault search cache TTL (ms) — drops to 0 instantly on writes through
# the API or fs.watch detecting external Obsidian edits. The TTL is the
# fallback for filesystems where fs.watch misbehaves.
# NEUROWORKS_VAULT_SEARCH_TTL_MS=60000

# Per-root fs.find_in listing cache TTL (ms). Lower = pickier about
# detecting newly-arrived downloads; the dir-mtime check makes this
# mostly belt-and-suspenders.
# NEUROWORKS_FIND_CACHE_TTL_MS=30000

# Reflection scheduler. Hour-of-day (0-23) for the nightly run. Set to
# 0 to disable the scheduler entirely (manual /api/reflection/run still
# works).
# NEUROWORKS_REFLECTION_HOUR=2
# NEUROWORKS_REFLECTION=0

# Disable the vault file watcher (falls back to 60s search-cache TTL).
# NEUROWORKS_VAULT_WATCH=0

# Reach-origin retry / rebase on push rejection. Default OFF — when the
# remote diverges, the local commit is durable but we DON'T auto-rebase
# (the previous behaviour could drop into a paused rebase state). Set
# to 1 if you want auto-rebase recovery anyway.
# NEUROWORKS_AUTO_REBASE_RECOVERY=1


# ═════════════════════════════════════════════════════════════════════
# Optional integrations
# ═════════════════════════════════════════════════════════════════════

# --- Brave browser read-only access ---------------------------------
# When enabled, the agent can list your open Brave tabs and read their
# content via the Chrome DevTools Protocol (read-only — no clicks,
# no navigation). Setup:
#   1. Close all Brave windows.
#   2. Launch Brave with: --remote-debugging-port=9222
#      e.g. "C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe" --remote-debugging-port=9222
#   3. Set NEUROWORKS_BRAVE_READ=1 and restart the server.
# Privacy note: this exposes the URLs and visible text of every open
# tab to the agent. Only enable if you're comfortable with that.
# NEUROWORKS_BRAVE_READ=1
# BRAVE_DEBUG_PORT=9222

# --- Email bridge (talk to clawbot over email) ----------------------
# Gives clawbot a mailbox: it polls for unseen mail over IMAP and replies
# over SMTP. Subject keyword routes the pipeline — "[team] ..." uses the
# multi-persona dispatch, anything else (or "[chat] ...") runs the chat
# pipeline. Use a DEDICATED Gmail account + an APP PASSWORD (not the real
# account password): Google Account → Security → 2-Step Verification →
# App passwords. https://myaccount.google.com/apppasswords
#
# SECURITY: inbound only acts on senders in NEUROWORKS_EMAIL_ALLOWED_SENDERS.
# Leave that blank and inbound stays OFF (outbound send still works) — an
# open bridge would let anyone email-trigger jobs against your machine.
# NEUROWORKS_EMAIL_USER=clawbot@gmail.com
# NEUROWORKS_EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# NEUROWORKS_EMAIL_FROM=clawbot@gmail.com
# NEUROWORKS_EMAIL_ALLOWED_SENDERS=you@example.com,teammate@example.com
# NEUROWORKS_EMAIL_POLL_MS=30000
# Defaults below are Gmail; override for another provider.
# NEUROWORKS_EMAIL_IMAP_HOST=imap.gmail.com
# NEUROWORKS_EMAIL_IMAP_PORT=993
# NEUROWORKS_EMAIL_SMTP_HOST=smtp.gmail.com
# NEUROWORKS_EMAIL_SMTP_PORT=465
# Hard-disable the bridge even if creds are present.
# NEUROWORKS_EMAIL=0
#
# Mailjet HTTPS API alternative for OUTBOUND only. When BOTH halves are
# set, outbound email goes via api.mailjet.com/v3.1/send instead of
# nodemailer SMTP (better deliverability + no SMTP creds needed). Inbound
# (IMAP) still uses the Gmail vars above. The From: domain MUST be
# verified in the Mailjet dashboard or sends will be rejected at their end.
# Get the pair at https://app.mailjet.com/account/apikeys
# NEUROWORKS_MAILJET_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEUROWORKS_MAILJET_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# UI Terminal page — when set to 1, the web Terminal (sidebar → System →
# Terminal) can run ARBITRARY shell commands on the host with the server's
# privileges. The server binds to 127.0.0.1 only. Off by default. Same trust
# model as code.exec: only enable on a machine you control.
# NEUROWORKS_TERMINAL=1

# Inbound email transport. "webhook" = Mailjet Parse API POSTs to a token-gated
# webhook on its OWN port (the only thing exposed via a public tunnel — see
# tools/inbound-tunnel.mjs). "imap" = legacy Gmail poll. "off" = outbound only.
# NEUROWORKS_EMAIL_INBOUND_MODE=webhook
# NEUROWORKS_EMAIL_INBOUND_PORT=7475
# Shared secret for the webhook (?token=). Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# NEUROWORKS_EMAIL_INBOUND_TOKEN=
# Anti-spoofing: the From header is verified against SPF/DKIM (Authentication-
# Results). Explicit auth failures are always rejected. Set to "strict" to ALSO
# reject mail we can't verify (no Authentication-Results header at all).
# NEUROWORKS_EMAIL_REQUIRE_AUTH=strict

# Calendar feed — an iCal URL (or a local .ics path) the agent reads for your
# real meetings (calendar.read_today / calendar.plan_day / the daily briefing).
# Unset = no meetings (the calendar still shows agent activity + dated memory
# commitments; the tools degrade gracefully). Get a feed from:
#   Google Calendar → Settings → <calendar> → "Secret address in iCal format"
#   Outlook         → Settings → Calendar → Shared calendars → Publish → ICS link
# NEUROWORKS_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics


# ═════════════════════════════════════════════════════════════════════
# Multi-clawbot (rare)
# ═════════════════════════════════════════════════════════════════════

# Identity for this instance — surfaces in /api/health and logs so
# primary + secondary can be told apart in dual-clawbot setups.
# NEUROWORKS_NAME=primary
# NEUROWORKS_ROLE=primary

# Comma-separated peer URLs. Empty = single-clawbot mode. Auto-discovery
# scans localhost every 60s so manual setup is usually unnecessary.
# NEUROWORKS_PEERS=http://127.0.0.1:7473

# Disable the boot-time auto-spawn of a managed secondary worker.
# NEUROWORKS_AUTO_SPAWN_WORKER=0


# ═════════════════════════════════════════════════════════════════════
# Load tuning — throughput under many concurrent tasks
# ═════════════════════════════════════════════════════════════════════

# Worker pool size (managed secondary agents the primary delegates to).
# Default 3, max 6. Each worker is a Node process on its own port that
# SHARES the one local Ollama — so >1 worker only adds throughput when
# tasks route to OpenRouter (which parallelises server-side). On a single
# local Ollama, extra workers just queue behind the one model.
# NEUROWORKS_MAX_WORKERS=4
# Primary delegates ALL ad-hoc tasks to the lightest worker and acts as
# editor/curator (1, default). Set 0 to only delegate when overloaded.
# NEUROWORKS_DELEGATE_ALL=1

# Bounded job queue — cap how many task jobs RUN at once; the rest wait in
# FIFO order instead of all hitting the LLM together (avoids the free-tier
# thundering-herd where 6 parallel tasks all stall on rate limits). 0 =
# unbounded (legacy fire-and-forget). Tune to your inference ceiling.
# NEUROWORKS_MAX_CONCURRENT_JOBS=3

# Ollama server parallelism — NOT read here; set these in the OLLAMA
# server's environment (e.g. `setx OLLAMA_NUM_PARALLEL 4` on Windows, then
# restart Ollama). NUM_PARALLEL = concurrent requests the model serves;
# MAX_LOADED_MODELS = models kept resident. This is the real throughput
# lever when you're local-only — pool size is downstream of it.
#   OLLAMA_NUM_PARALLEL=4
#   OLLAMA_MAX_LOADED_MODELS=2


# ═════════════════════════════════════════════════════════════════════
# External agent dispatch (orchestration layer)
# ═════════════════════════════════════════════════════════════════════
# Other systems call POST /api/v1/dispatch with an API key (mint one in the UI
# or via POST /api/dispatch-keys). These two tune the webhook callback:
#
# HMAC secret used to sign completion webhooks (header X-NeuroWorks-Signature).
# Leave blank to send unsigned callbacks. Set a long random value in production.
#   NW_WEBHOOK_SIGNING_SECRET=
# Allow webhook callbacks to private/loopback/link-local addresses. Off by
# default (SSRF guard). Set to 1 ONLY if your callback receiver is internal.
#   NW_WEBHOOK_ALLOW_PRIVATE=0


# ═════════════════════════════════════════════════════════════════════
# Production deployment (container / cloud VM)
# ═════════════════════════════════════════════════════════════════════
# Locally (pnpm dev) none of these are needed — the Vite dev server serves the
# web UI and the API stays on loopback. In the container the API serves the
# BUILT SPA itself on a single port. The Dockerfile sets these; listed here so
# a bare `node`/`pnpm start` deploy can match.
#
# Serve the built web/dist from the API (run `pnpm -F clawbot-web build` first).
#   SERVE_WEB=1
# Bind beyond loopback so the published port is reachable (container/VM only).
#   NEUROWORKS_BIND_HOST=0.0.0.0
# Fail-fast strict env validation. Auto-on when NODE_ENV=production; force with:
#   NEUROWORKS_STRICT_ENV=1
# Extra Host header values the origin-guard accepts (DNS-rebind defense) when
# the deployed SPA + API share your real hostname. Comma-separated.
#   NEUROWORKS_ALLOWED_HOSTS=neuroworks.example.com,neuroworks.example.com:7471
# Graceful-shutdown grace before a forced exit (ms). Default 12000.
#   NEUROWORKS_SHUTDOWN_GRACE_MS=12000


# ═════════════════════════════════════════════════════════════════════
# Finance System link (public ingest)
# ═════════════════════════════════════════════════════════════════════
# The company Finance System PUSHES its figures to NeuroWorks:
#   POST /api/public/dashboard   (store)   ·   POST /api/public/sync  (alias)
#   GET  /api/public/dashboard   (live snapshot — 5 mapped fields)
# Optional shared secret. When set, pushes must send it as
# `Authorization: Bearer <token>` or `X-Finance-Token: <token>`. Unset = open
# ingest (fine on a trusted network). GET stays open (it's the public dashboard).
#   FINANCE_SYNC_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Paynow (Zimbabwe) — local-market payments (EcoCash, OneMoney, cards)
# ─────────────────────────────────────────────────────────────────────
# Both required to enable. From your Paynow merchant dashboard.
# PAYNOW_INTEGRATION_ID=12345
# PAYNOW_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Auth email for 3rd-party integrations (defaults to the operator's address).
# PAYNOW_MERCHANT_EMAIL=you@company.com
# Where Paynow POSTs status updates (must be publicly reachable in prod) and
# where the payer lands after paying.
# PAYNOW_RESULT_URL=https://your-host/api/payments/paynow/result
# PAYNOW_RETURN_URL=https://your-host/paid

# ─────────────────────────────────────────────────────────────────────
# Anthropic provider cost tiering (Models page provider)
# ─────────────────────────────────────────────────────────────────────
# Cheap tier — planning, extraction, normal-sized synthesis. Default
# claude-haiku-4-5 ($1/$5 per MTok). Complex calls (complexity:"high" or
# prompts over NEUROWORKS_LOCAL_CTX_BUDGET tokens) hand off to the large tier
# (default = the provider's chosen model, e.g. claude-fable-5).
# ANTHROPIC_SMALL_MODEL=claude-haiku-4-5
# ANTHROPIC_LARGE_MODEL=claude-sonnet-5
