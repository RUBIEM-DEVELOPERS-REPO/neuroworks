# Copy to .env and fill in. .env is gitignored.

# GitHub PAT — same one used for clawbot CLAWBOT_PAT (Contents r/w, Workflows r/w, etc.)
GITHUB_TOKEN=ghp_paste_here

# Owner used by publish-folder and the NeuroWorks UI
GITHUB_OWNER=RUBIEM-DEVELOPERS-REPO

# Vault repo (owner/name) — clawbot writes summaries here
VAULT_REPO=RUBIEM-DEVELOPERS-REPO/main-brain

# Local path to the Obsidian vault — server reads/writes here
VAULT_PATH=D:\Main brain

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# OpenRouter (optional, big speed gain on planning/synthesis)
# Leaving OPENROUTER_API_KEY blank keeps everything 100% local on Ollama.
# Set the key and any of the OPENROUTER_* model pins below to route specific
# profiles to OR. Free profile model overrides take precedence over the
# default; OPENROUTER_PROFILES (comma list) narrows which profiles use OR.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_LARGE_MODEL=openai/gpt-4o
# OPENROUTER_PROFILES=planning,synthesis,triage,extraction,balanced
# OPENROUTER_PLAN_MODEL=openai/gpt-4o-mini
# OPENROUTER_SYNTH_MODEL=anthropic/claude-3.5-haiku
# OPENROUTER_TRIAGE_MODEL=openai/gpt-4o-mini
# OPENROUTER_EXTRACT_MODEL=openai/gpt-4o-mini
# OPENROUTER_BALANCED_MODEL=openai/gpt-4o-mini
# OPENROUTER_APP_URL=https://neuroworks.local
# OPENROUTER_APP_NAME=NeuroWorks Clawbot

# Firecrawl (optional — hosted scraping API used as a third tier when vanilla
# fetch + local Playwright both fail or get blocked by anti-bot). Get a key
# from https://firecrawl.dev — once set, smartFetch automatically tries
# Firecrawl after Playwright fails, and the web.firecrawl primitive becomes
# available to the planner.
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Remote skill fetch (off by default — set to 1 to allow skill.fetch_remote
# to pull skill .md files from public URLs into skills/_user/). Keep off
# unless you trust the source of the skill files you'd be fetching.
# CLAWBOT_REMOTE_SKILLS=1

# Vault edits (off by default — set to 1 to allow clawbot to modify your vault docs).
# When enabled, the agent can use vault.edit to apply an instruction to a markdown
# file. Approve only when you trust the agent loop with write access to .md notes
# in your vault. Reads (vault.read, vault.scan_docs, vault.search) are always on.
# CLAWBOT_VAULT_EDIT=1

# NeuroWorks server bind
NEUROWORKS_PORT=7471
