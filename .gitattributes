# Keep shell hooks + scripts as LF. On Windows, Git's autocrlf can rewrite them
# to CRLF, which breaks the `#!/bin/sh` shebang and makes git silently skip the
# hook (a secret-guard that doesn't run is worse than none). Scoped narrowly so
# this does NOT renormalize the rest of the repo.
tools/git-hooks/* text eol=lf
*.sh text eol=lf

# Skill playbooks are parsed with a frontmatter regex that requires bare \n
# (server/src/lib/skills.ts). CRLF from a Windows checkout silently zeroes
# out every skill's applies_to intent matching (parser also normalizes CRLF
# now as defense in depth, but keep the checkout itself clean).
server/src/skills/*.md text eol=lf
